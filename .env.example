# ============================
# Base de Datos PostgreSQL
# ============================

DB_USER=username
DB_PASSWORD=example_password
DB_NAME=name_db
DB_PORT=5432

# URL que usa el backend; mantiene la estructura:
# En Neon, reemplaza host y credenciales por los que te da Neon.
DATABASE_URL=postgres://username:example_password@db.neon.tech:5432/name_db?sslmode=require
DB_SSL=true

# ============================
# Frontend
# ============================

FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api/profesionales

# ============================
# Backend
# ============================

PORT=3000
NODE_ENV=development
